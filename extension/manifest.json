{
  "manifest_version": 3,
  "name": "DAB Meetings Recorder",
  "version": "1.0.0",
  "description": "Record Google Meet and Microsoft Teams calls and send them to DAB Meetings for transcription.",

  "permissions": ["tabCapture", "offscreen", "storage", "activeTab"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://teams.microsoft.com/*",
    "https://teams.live.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://teams.microsoft.com/*",
        "https://teams.live.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "DAB Meetings Recorder"
  }
}
