generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String?
  email        String        @unique
  passwordHash String
  role         String        @default("user")
  createdAt    DateTime      @default(now())
  meetings     Meeting[]
  series       MeetingSeries[]
  settings     UserSettings?
}

model MeetingSeries {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime  @default(now())
  meetings  Meeting[]
}

model Meeting {
  id          String          @id @default(cuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  seriesId    String?
  series      MeetingSeries?  @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  title       String          @default("Untitled Meeting")
  date        DateTime        @default(now())
  audioPath   String?
  transcript  String?         @db.Text
  minutes     String?         @db.Text
  language    String          @default("en")
  attendees   String          @default("")
  agenda      String?         @db.Text
  tags        String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  actionItems ActionItem[]
  shareLinks  ShareLink[]
}

model ShareLink {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

model ActionItem {
  id        String    @id @default(cuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  text      String
  assignee  String?
  priority  String    @default("medium")
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())
}

model UserSettings {
  id                      String  @id @default(cuid())
  userId                  String  @unique
  user                    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Transcription provider: "whisper" | "groq" | "webspeech" | "assemblyai"
  transcriptionProvider   String  @default("groq")
  groqApiKey              String  @default("")
  assemblyAiApiKey        String  @default("")
  whisperHost             String  @default("whisper")
  whisperPort             String  @default("9000")
  whisperPath             String  @default("/v1/audio/transcriptions")
  whisperModel            String  @default("whisper-1")
  whisperLang             String  @default("")
  whisperProto            String  @default("http")
  ollamaHost              String  @default("172.17.0.1")
  ollamaPort              String  @default("11211")
  ollamaModel             String  @default("mistral:7b-instruct")
  ollamaProto             String  @default("http")
  audioFormat             String  @default("audio/webm")
  emailRecipients         String  @default("")
  logoDataUrl             String? @db.Text
  theme                   String  @default("dark")
  useProxy                Boolean @default(true)
  lowMemoryMode           Boolean @default(true)
  extensionApiKey         String  @default("")
  webhookUrl              String  @default("")
  smtpHost                String  @default("")
  smtpPort                String  @default("587")
  smtpUser                String  @default("")
  smtpPassword            String  @default("")
  smtpFrom                String  @default("")
  smtpSecure              Boolean @default(false)
  calendarUrl             String  @default("")
}
